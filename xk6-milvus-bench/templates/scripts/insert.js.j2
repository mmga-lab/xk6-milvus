import milvus from 'k6/x/milvus';
import { check, sleep } from 'k6';
import { Trend, Counter, Rate } from 'k6/metrics';

// ============================================================================
// Configuration
// ============================================================================

const CONFIG = {
    host: __ENV.MILVUS_HOST || '{{ milvus.host }}',
    token: __ENV.MILVUS_TOKEN || '{{ milvus.token }}',
    vectorDim: {{ collection.vector_dim }},
    batchSize: {{ scenario.setup.batch_size }},
    index: {
        type: '{{ collection.index.type }}',
        metric: '{{ collection.index.metric }}',
        params: {{ collection.index.params | tojson }},
    },
};

// ============================================================================
// Custom Metrics
// ============================================================================

const insertLatency = new Trend('milvus_insert_latency', true);
const insertOps = new Counter('milvus_insert_ops');
const insertRecords = new Counter('milvus_insert_records');
const errorRate = new Rate('milvus_errors');

// Batch size variants
const smallBatchLatency = new Trend('milvus_small_batch_latency', true);
const mediumBatchLatency = new Trend('milvus_medium_batch_latency', true);
const largeBatchLatency = new Trend('milvus_large_batch_latency', true);

// ============================================================================
// k6 Options
// ============================================================================

export const options = {
{% if execution.stages %}
    stages: [
{% for stage in execution.stages %}
        { duration: '{{ stage.duration }}', target: {{ stage.target }} },
{% endfor %}
    ],
{% else %}
    vus: {{ execution.vus }},
    duration: '{{ execution.duration }}',
{% endif %}
    thresholds: {
        'milvus_insert_latency': ['p(95)<{{ thresholds.insert_p95_ms }}'],
        'milvus_errors': ['rate<{{ thresholds.max_error_rate }}'],
        'milvus_small_batch_latency': ['p(95)<200'],
        'milvus_medium_batch_latency': ['p(95)<500'],
        'milvus_large_batch_latency': ['p(95)<1000'],
    },
    tags: {
        scenario: '{{ scenario.name }}',
        type: 'insert',
        testrun: __ENV.TESTRUN_NAME || 'local',
    },
};

// ============================================================================
// Helper Functions
// ============================================================================

function generateVector(dim) {
    const vector = new Array(dim);
    for (let i = 0; i < dim; i++) {
        vector[i] = Math.random();
    }
    return vector;
}

function generateVectors(count, dim) {
    const vectors = new Array(count);
    for (let i = 0; i < count; i++) {
        vectors[i] = generateVector(dim);
    }
    return vectors;
}

function generateBatchData(count, dim) {
    const categories = ['electronics', 'clothing', 'books', 'food', 'toys', 'sports', 'home', 'garden'];
    const brands = ['brand_a', 'brand_b', 'brand_c', 'brand_d', 'brand_e'];

    return {
        category: Array.from({ length: count }, () => categories[Math.floor(Math.random() * categories.length)]),
        brand: Array.from({ length: count }, () => brands[Math.floor(Math.random() * brands.length)]),
        price: Array.from({ length: count }, () => Math.random() * 1000),
        stock: Array.from({ length: count }, () => Math.floor(Math.random() * 1000)),
        embedding: generateVectors(count, dim),
    };
}

// ============================================================================
// Setup
// ============================================================================

export function setup() {
    console.log('='.repeat(60));
    console.log('Insert Performance Test Setup');
    console.log('='.repeat(60));
    console.log(`Target: ${CONFIG.host}`);
    console.log(`Vector Dim: ${CONFIG.vectorDim}`);
    console.log(`Batch Size: ${CONFIG.batchSize}`);

    const client = milvus.client(CONFIG.host, CONFIG.token);
    const collectionName = `perf_insert_${Date.now()}`;

    // Create collection with extended schema
    const schema = {
        name: collectionName,
        fields: [
            { name: 'id', dataType: 'Int64', isPrimaryKey: true, isAutoID: true },
            { name: 'category', dataType: 'VarChar', maxLength: 50 },
            { name: 'brand', dataType: 'VarChar', maxLength: 50 },
            { name: 'price', dataType: 'Float' },
            { name: 'stock', dataType: 'Int64' },
            { name: 'embedding', dataType: 'FloatVector', dimension: CONFIG.vectorDim },
        ],
    };

    const createResult = client.createCollection(schema);
    if (!createResult.success) {
        throw new Error(`Failed to create collection: ${createResult.error}`);
    }
    console.log(`Collection created: ${collectionName}`);

    // Create index (for later search tests)
    const indexResult = client.createIndex('embedding', {
        indexType: CONFIG.index.type,
        metricType: CONFIG.index.metric,
        params: CONFIG.index.params,
    }, collectionName);

    if (!indexResult.success) {
        console.warn(`Index creation failed: ${indexResult.error}`);
    } else {
        console.log(`Index created: ${CONFIG.index.type}`);
    }

    // Load collection
    const loadResult = client.loadCollection(collectionName);
    if (!loadResult.success) {
        console.warn(`Load collection failed: ${loadResult.error}`);
    }

    client.close();
    console.log('Setup complete');
    console.log('='.repeat(60));

    return {
        collection: collectionName,
        startTime: Date.now(),
    };
}

// ============================================================================
// Main Test
// ============================================================================

export default function(data) {
    const client = milvus.clientWithCollection(CONFIG.host, data.collection, CONFIG.token);

    // Test with different batch sizes
    const batchSizes = {
        small: 10,
        medium: 100,
        large: 1000,
    };

    // --- Small Batch Insert ---
    {
        const batchData = generateBatchData(batchSizes.small, CONFIG.vectorDim);
        const result = client.insert(batchData);

        insertLatency.add(result.response_time_ms);
        smallBatchLatency.add(result.response_time_ms);
        insertOps.add(1);
        errorRate.add(!result.success);

        if (result.success) {
            insertRecords.add(result.result.insert_count || batchSizes.small);
        }

        check(result, {
            'small_batch_insert_success': (r) => r.success === true,
            'small_batch_has_count': (r) => r.result && r.result.insert_count > 0,
        });
    }

    // --- Medium Batch Insert ---
    {
        const batchData = generateBatchData(batchSizes.medium, CONFIG.vectorDim);
        const result = client.insert(batchData);

        insertLatency.add(result.response_time_ms);
        mediumBatchLatency.add(result.response_time_ms);
        insertOps.add(1);
        errorRate.add(!result.success);

        if (result.success) {
            insertRecords.add(result.result.insert_count || batchSizes.medium);
        }

        check(result, {
            'medium_batch_insert_success': (r) => r.success === true,
            'medium_batch_has_count': (r) => r.result && r.result.insert_count > 0,
        });
    }

    // --- Large Batch Insert ---
    {
        const batchData = generateBatchData(batchSizes.large, CONFIG.vectorDim);
        const result = client.insert(batchData);

        insertLatency.add(result.response_time_ms);
        largeBatchLatency.add(result.response_time_ms);
        insertOps.add(1);
        errorRate.add(!result.success);

        if (result.success) {
            insertRecords.add(result.result.insert_count || batchSizes.large);
        }

        check(result, {
            'large_batch_insert_success': (r) => r.success === true,
            'large_batch_has_count': (r) => r.result && r.result.insert_count > 0,
        });
    }

    client.close();
    sleep(0.1);
}

// ============================================================================
// Teardown
// ============================================================================

export function teardown(data) {
    const duration = (Date.now() - data.startTime) / 1000;
    console.log('='.repeat(60));
    console.log('Insert Test Summary');
    console.log('='.repeat(60));
    console.log(`Total Duration: ${duration.toFixed(2)}s`);

    console.log('Cleaning up...');
    const client = milvus.client(CONFIG.host, CONFIG.token);
    const result = client.dropCollection(data.collection);

    if (result.success) {
        console.log(`Collection ${data.collection} dropped`);
    } else {
        console.error(`Failed to drop collection: ${result.error}`);
    }

    client.close();
    console.log('Teardown complete');
}
