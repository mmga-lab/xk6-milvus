export default function(data) {
    const elementClient = milvus.getClient(CONFIG.host, data.elementCollection, CONFIG.token);
    const embeddingListClient = milvus.getClient(CONFIG.host, data.embeddingListCollection, CONFIG.token);
    const variants = CONFIG.structArray.stableVariants;
    const variant = variants[__ITER % variants.length];

    if (variant === 'normal_vector_search') {
        runSearch(elementClient, variant, [generateVector(queryID() + 1000, CONFIG.vectorDim)], {
            vectorField: CONFIG.structArray.normalVectorField,
            metricType: CONFIG.structArray.normalMetric,
            outputFields: CONFIG.outputFields,
            params: { ef: CONFIG.search.ef, nprobe: CONFIG.search.nprobe },
        });
    } else if (variant === 'element_search') {
        runSearch(elementClient, variant, [singleElementQueryVector()], {
            vectorField: CONFIG.structArray.vectorField,
            metricType: CONFIG.structArray.elementMetric,
            outputFields: CONFIG.outputFields,
            params: { ef: CONFIG.search.ef, nprobe: CONFIG.search.nprobe },
        });
    } else if (variant === 'element_filter_search') {
        runSearch(elementClient, variant, [singleElementQueryVector()], {
            vectorField: CONFIG.structArray.vectorField,
            metricType: CONFIG.structArray.elementMetric,
            outputFields: CONFIG.outputFields,
            filter: 'element_filter(structA, ($[color] == "Red" || $[color] == "Blue") && $[int_val] >= 0)',
            params: { ef: CONFIG.search.ef, nprobe: CONFIG.search.nprobe },
        });
    } else if (variant === 'embedding_list_search') {
        runSearch(embeddingListClient, variant, [embeddingListQueryVector()], {
            vectorField: CONFIG.structArray.vectorField,
            metricType: CONFIG.structArray.embeddingListMetric,
            outputFields: CONFIG.outputFields,
            params: { ef: CONFIG.search.ef, nprobe: CONFIG.search.nprobe },
        });
    } else if (variant === 'element_filter_query') {
        runQuery(elementClient, variant, 'element_filter(structA, $[color] == "Red" && $[int_val] >= 0)');
    } else if (variant === 'match_any_query') {
        runQuery(elementClient, variant, 'MATCH_ANY(structA, $[color] == "Red" && $[size] == "S")');
    } else if (variant === 'match_threshold_query') {
        runQuery(elementClient, variant, 'MATCH_LEAST(structA, $[int_val] >= 0, threshold=2)');
    } else if (variant === 'array_contains_query') {
        runQuery(elementClient, variant, 'array_contains(structA[color], "Red")');
    } else if (variant === 'array_contains_any_query') {
        runQuery(elementClient, variant, 'array_contains_any(structA[category], ["A", "B"])');
    } else if (variant === 'array_length_query') {
        runQuery(elementClient, variant, `array_length(structA[color]) >= ${CONFIG.structArray.minElements}`);
    } else if (variant === 'struct_index_in_query') {
        runQuery(elementClient, variant, 'structA[0][color] in ["Red", "Blue"]');
    } else if (variant === 'group_by_pk_search') {
        runSearch(elementClient, variant, [singleElementQueryVector()], {
            vectorField: CONFIG.structArray.vectorField,
            metricType: CONFIG.structArray.elementMetric,
            outputFields: CONFIG.outputFields,
            groupByField: 'id',
            groupSize: 1,
            params: { ef: CONFIG.search.ef, nprobe: CONFIG.search.nprobe },
        });
    } else {
        throw new Error(`Unknown struct-array variant: ${variant}`);
    }

    sleep(0.05);
}

export function teardown(data) {
    console.log('Cleaning up struct-array benchmark collections...');
    const admin = milvus.client(CONFIG.host, CONFIG.token);

    for (const collectionName of [data.elementCollection, data.embeddingListCollection]) {
        const result = admin.dropCollection(collectionName);
        if (result.success) {
            console.log(`Dropped ${collectionName}`);
        } else {
            console.error(`Failed to drop ${collectionName}: ${result.error}`);
        }
    }

    admin.close();
    console.log('Struct-array teardown complete');
}
