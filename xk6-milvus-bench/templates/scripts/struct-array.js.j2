            size: CONFIG.structArray.sizes[(rowID * 3 + j) % CONFIG.structArray.sizes.length],
            category: CONFIG.structArray.categories[(rowID + j * 2) % CONFIG.structArray.categories.length],
            tag: `row_${rowID}_elem_${j}`,
