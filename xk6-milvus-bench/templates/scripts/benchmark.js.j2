// Configuration
// ============================================================================

const CONFIG = {
    host: __ENV.MILVUS_HOST || '{{ milvus.host }}',
    token: __ENV.MILVUS_TOKEN || '{{ milvus.token }}',

    // Dataset configuration
    dataset: {
        name: '{{ scenario.benchmark.dataset }}',
        trainPath: __ENV.DATASET_TRAIN_PATH || '{{ scenario.benchmark.train_path }}',
        testPath: __ENV.DATASET_TEST_PATH || '{{ scenario.benchmark.test_path }}',
        neighborsPath: __ENV.DATASET_NEIGHBORS_PATH || '{{ scenario.benchmark.neighbors_path }}',
        dimension: {{ scenario.benchmark.dimension }},
        metric: '{{ scenario.benchmark.metric }}',
    },

    // Search parameters
    search: {
        topK: {{ scenario.search.topk }},
        nprobe: {{ scenario.search.nprobe }},
        ef: {{ scenario.search.ef }},
    },

    // Index configuration
    index: {
        type: '{{ collection.index.type }}',
        metric: '{{ scenario.benchmark.metric }}',
        params: {{ collection.index.params | tojson }},
    },

    // Recall thresholds
    recall: {
        minRecall: {{ thresholds.min_recall }},
        recallK: {{ scenario.search.topk }},  // Calculate recall@K
    },
};

// ============================================================================
// Load Dataset using SharedArray (shared across VUs)
// ============================================================================

// Load query vectors
const queryVectors = new SharedArray('queryVectors', function() {
    console.log(`Loading query vectors from ${CONFIG.dataset.testPath}...`);
    const data = parquet.read(CONFIG.dataset.testPath);
    console.log(`Loaded ${data.length} query vectors`);
    return data;
});

// Load ground truth neighbors
const groundTruth = new SharedArray('groundTruth', function() {
    console.log(`Loading ground truth from ${CONFIG.dataset.neighborsPath}...`);
    const data = parquet.read(CONFIG.dataset.neighborsPath);
    console.log(`Loaded ${data.length} ground truth entries`);
    return data;
});

// ============================================================================
// Custom Metrics
// ============================================================================

// Latency metrics
const searchLatency = new Trend('milvus_search_latency', true);
const searchOps = new Counter('milvus_search_ops');

// Recall metrics (真实召回率)
const recallMetric = new Trend('milvus_recall');
const recall1 = new Trend('milvus_recall_1');    // Recall@1
const recall10 = new Trend('milvus_recall_10');  // Recall@10
const recall100 = new Trend('milvus_recall_100'); // Recall@100

// Quality metrics
const errorRate = new Rate('milvus_errors');
const emptyRate = new Rate('milvus_empty_results');

// Query tracking
const queryIndex = new Gauge('milvus_query_index');

// ============================================================================
// k6 Options
// ============================================================================

export const options = {
{% if execution.stages %}
    stages: [
{% for stage in execution.stages %}
        { duration: '{{ stage.duration }}', target: {{ stage.target }} },
{% endfor %}
    ],
{% else %}
    vus: {{ execution.vus }},
    duration: '{{ execution.duration }}',
{% endif %}
    thresholds: {
        'milvus_search_latency': ['p(95)<{{ thresholds.search_p95_ms }}', 'p(99)<{{ thresholds.search_p99_ms }}'],
        'milvus_recall': ['avg>={{ (thresholds.min_recall * 100) | int }}'],
        'milvus_recall_10': ['avg>={{ (thresholds.min_recall * 100) | int }}'],
        'milvus_errors': ['rate<{{ thresholds.max_error_rate }}'],
    },
    tags: {
        scenario: '{{ scenario.name }}',
        dataset: '{{ scenario.benchmark.dataset }}',
        type: 'benchmark',
        testrun: __ENV.TESTRUN_NAME || 'local',
    },
};

// ============================================================================
// Helper Functions
// ============================================================================

/**
 * Calculate recall@K between search results and ground truth
 * @param {Array} searchResults - Array of result IDs from search
 * @param {Array} groundTruthIds - Array of true neighbor IDs
 * @param {number} k - K value for recall@K
 * @returns {number} Recall value between 0 and 1
 */
function calculateRecall(searchResults, groundTruthIds, k) {
    if (!searchResults || searchResults.length === 0) {
        return 0;
    }

    // Get top-K from search results
    const topK = searchResults.slice(0, k);

    // Get top-K from ground truth
    const trueTopK = groundTruthIds.slice(0, k);

    // Count hits
    const searchSet = new Set(topK);
    let hits = 0;
    for (const id of trueTopK) {
        if (searchSet.has(id)) {
            hits++;
        }
    }

    return hits / k;
}

/**
 * Extract IDs from search results
 */
function extractResultIds(searchResult) {
    if (!searchResult.success || searchResult.empty || !searchResult.result) {
        return [];
    }

    // searchResult.result 是搜索结果数组
    // 每个结果应该包含 id 字段
    return searchResult.result.map(r => r.id || r.ID || r.Id);
}

// ============================================================================
// Setup: Create collection and load training data
// ============================================================================

export function setup() {
    console.log('='.repeat(60));
    console.log('Benchmark Test Setup');
    console.log('='.repeat(60));
    console.log(`Dataset: ${CONFIG.dataset.name}`);
    console.log(`Dimension: ${CONFIG.dataset.dimension}`);
    console.log(`Metric: ${CONFIG.dataset.metric}`);
    console.log(`Query vectors: ${queryVectors.length}`);
    console.log(`Ground truth entries: ${groundTruth.length}`);

    const client = milvus.client(CONFIG.host, CONFIG.token);
    const collectionName = `benchmark_${CONFIG.dataset.name.replace(/-/g, '_')}_${Date.now()}`;

    // Create collection
    const schema = {
        name: collectionName,
        fields: [
            { name: 'id', dataType: 'Int64', isPrimaryKey: true },
            { name: 'vector', dataType: 'FloatVector', dimension: CONFIG.dataset.dimension },
        ],
    };

    const createResult = client.createCollection(schema);
    if (!createResult.success) {
        throw new Error(`Failed to create collection: ${createResult.error}`);
    }
    console.log(`Collection created: ${collectionName}`);

    // Load training data and insert
    console.log(`Loading training data from ${CONFIG.dataset.trainPath}...`);

    // Use chunked reading for large datasets
    let totalInserted = 0;
    const batchSize = {{ scenario.setup.batch_size }};

    parquet.readChunked(CONFIG.dataset.trainPath, batchSize, (chunk) => {
        // Prepare data for insert
        const ids = chunk.map(row => row.id);
        const vectors = chunk.map(row => row.vector);

        const insertResult = client.insert({
            id: ids,
            vector: vectors,
        }, collectionName);

        if (insertResult.success) {
            totalInserted += insertResult.result.insert_count || chunk.length;
            if (totalInserted % 100000 === 0) {
                console.log(`Inserted ${totalInserted} vectors...`);
            }
        } else {
            console.error(`Insert failed: ${insertResult.error}`);
        }

        return null; // Continue processing
    });

    console.log(`Total inserted: ${totalInserted} vectors`);

    // Create index
    console.log('Creating index...');
    const indexResult = client.createIndex('vector', {
        indexType: CONFIG.index.type,
        metricType: CONFIG.index.metric,
        params: CONFIG.index.params,
    }, collectionName);

    if (!indexResult.success) {
        throw new Error(`Failed to create index: ${indexResult.error}`);
    }
    console.log(`Index created: ${CONFIG.index.type}`);

    // Load collection
    const loadResult = client.loadCollection(collectionName);
    if (!loadResult.success) {
        throw new Error(`Failed to load collection: ${loadResult.error}`);
    }
    console.log('Collection loaded into memory');

    client.close();
    console.log('Setup complete');
    console.log('='.repeat(60));

    return {
        collection: collectionName,
        trainSize: totalInserted,
        queryCount: queryVectors.length,
    };
}

// ============================================================================
// Main Test: Run benchmark queries
// ============================================================================

export default function(data) {
    const client = milvus.clientWithCollection(CONFIG.host, data.collection, CONFIG.token);

    // Select query based on VU and iteration (round-robin through all queries)
    const queryIdx = (__VU - 1 + __ITER * {{ execution.vus }}) % queryVectors.length;
    queryIndex.add(queryIdx);

    const queryData = queryVectors[queryIdx];
    const truthData = groundTruth[queryIdx];

    // Get query vector and ground truth neighbors
    const queryVector = queryData.vector;
    const trueNeighbors = truthData.neighbors;

    // Execute search
    const result = client.search(
        [queryVector],
        CONFIG.search.topK,
        {
            vectorField: 'vector',
            metricType: CONFIG.index.metric,
            outputFields: ['id'],
            params: {
                nprobe: CONFIG.search.nprobe,
                ef: CONFIG.search.ef,
            },
        }
    );

    // Record latency and ops
    searchLatency.add(result.response_time_ms);
    searchOps.add(1);
    errorRate.add(!result.success);
    emptyRate.add(result.empty);

    if (result.success && !result.empty) {
        // Extract result IDs
        const resultIds = extractResultIds(result);

        // Calculate recall at different K values
        const r1 = calculateRecall(resultIds, trueNeighbors, 1);
        const r10 = calculateRecall(resultIds, trueNeighbors, Math.min(10, CONFIG.search.topK));
        const rK = calculateRecall(resultIds, trueNeighbors, CONFIG.search.topK);

        recall1.add(r1 * 100);
        recall10.add(r10 * 100);
        recallMetric.add(rK * 100);

        if (CONFIG.search.topK >= 100) {
            const r100 = calculateRecall(resultIds, trueNeighbors, 100);
            recall100.add(r100 * 100);
        }

        check(result, {
            'search_successful': (r) => r.success === true,
            'has_results': (r) => !r.empty,
            'recall_above_threshold': () => rK >= CONFIG.recall.minRecall,
        });
    } else {
        check(result, {
            'search_successful': (r) => r.success === true,
        });
    }

    client.close();
    sleep(0.01);  // Small sleep to control query rate
}

// ============================================================================
// Teardown
// ============================================================================

export function teardown(data) {
    console.log('='.repeat(60));
    console.log('Benchmark Test Summary');
    console.log('='.repeat(60));
    console.log(`Collection: ${data.collection}`);
    console.log(`Train size: ${data.trainSize}`);
    console.log(`Query count: ${data.queryCount}`);
    console.log(`TopK: ${CONFIG.search.topK}`);
    console.log(`Index: ${CONFIG.index.type}`);
    console.log(`Metric: ${CONFIG.index.metric}`);

    // Cleanup
    console.log('Cleaning up...');
    const client = milvus.client(CONFIG.host, CONFIG.token);
    const result = client.dropCollection(data.collection);

    if (result.success) {
        console.log(`Collection ${data.collection} dropped`);
    } else {
        console.error(`Failed to drop collection: ${result.error}`);
    }

    // Close parquet resources
    parquet.close();

    client.close();
    console.log('Teardown complete');
}
