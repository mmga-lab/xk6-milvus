    dataSize: {{ scenario.setup.data_size }},
    batchSize: {{ scenario.setup.batch_size }},
    index: {
        type: '{{ collection.index.type }}',
        metric: '{{ collection.index.metric }}',
        params: {{ collection.index.params | tojson }},
    },
    search: {
        topK: {{ scenario.search.topk }},
        nprobe: {{ scenario.search.nprobe }},
        ef: {{ scenario.search.ef }},
    },
    minRecall: {{ thresholds.min_recall }},
};

// Test different topK values
const TOP_K_VALUES = [1, 5, 10, 50, 100];

// ============================================================================
// Custom Metrics
// ============================================================================

// Recall metrics by topK
{% for k in [1, 5, 10, 50, 100] %}
const recallTop{{ k }} = new Trend('milvus_recall_top{{ k }}');
{% endfor %}

const overallRecall = new Trend('milvus_recall');
const searchLatency = new Trend('milvus_search_latency', true);
const searchOps = new Counter('milvus_search_ops');
const errorRate = new Rate('milvus_errors');

// Recall distribution
const recallDistribution = new Trend('milvus_recall_distribution');
