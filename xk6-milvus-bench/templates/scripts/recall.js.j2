// ============================================================================
// Helper Functions
// ============================================================================

function generateVector(dim) {
    const vector = new Array(dim);
    for (let i = 0; i < dim; i++) {
        vector[i] = Math.random();
    }
    return vector;
}

function generateVectors(count, dim) {
    const vectors = new Array(count);
    for (let i = 0; i < count; i++) {
        vectors[i] = generateVector(dim);
    }
    return vectors;
}

function generateBatchData(count, dim) {
    const categories = ['electronics', 'clothing', 'books', 'food', 'toys'];
    return {
        category: Array.from({ length: count }, () => categories[Math.floor(Math.random() * categories.length)]),
        price: Array.from({ length: count }, () => Math.random() * 100),
        embedding: generateVectors(count, dim),
    };
}

// ============================================================================
// Setup
// ============================================================================

export function setup() {
    console.log('='.repeat(60));
    console.log('Recall Verification Test Setup');
    console.log('='.repeat(60));
    console.log(`Target: ${CONFIG.host}`);
    console.log(`Vector Dim: ${CONFIG.vectorDim}`);
    console.log(`Data Size: ${CONFIG.dataSize}`);
    console.log(`Index Type: ${CONFIG.index.type}`);
    console.log(`Min Required Recall: ${CONFIG.minRecall * 100}%`);

    const client = milvus.client(CONFIG.host, CONFIG.token);
    const collectionName = `perf_recall_${Date.now()}`;

    // Create collection
    const schema = {
        name: collectionName,
        fields: [
            { name: 'id', dataType: 'Int64', isPrimaryKey: true, isAutoID: true },
            { name: 'category', dataType: 'VarChar', maxLength: 50 },
            { name: 'price', dataType: 'Float' },
            { name: 'embedding', dataType: 'FloatVector', dimension: CONFIG.vectorDim },
        ],
    };

    const createResult = client.createCollection(schema);
    if (!createResult.success) {
        throw new Error(`Failed to create collection: ${createResult.error}`);
    }
    console.log(`Collection created: ${collectionName}`);

    // Create index
    const indexResult = client.createIndex('embedding', {
        indexType: CONFIG.index.type,
        metricType: CONFIG.index.metric,
        params: CONFIG.index.params,
    }, collectionName);

    if (!indexResult.success) {
        throw new Error(`Failed to create index: ${indexResult.error}`);
    }
    console.log(`Index created: ${CONFIG.index.type}`);

    // Load collection
    client.loadCollection(collectionName);

    // Insert test data
    console.log(`Inserting ${CONFIG.dataSize} records...`);
    const batches = Math.ceil(CONFIG.dataSize / CONFIG.batchSize);
    let totalInserted = 0;

    for (let i = 0; i < batches; i++) {
        const count = Math.min(CONFIG.batchSize, CONFIG.dataSize - i * CONFIG.batchSize);
        const data = generateBatchData(count, CONFIG.vectorDim);
        const result = client.insert(data, collectionName);

        if (result.success) {
            totalInserted += result.result.insert_count || count;
        }
    }

    console.log(`Total inserted: ${totalInserted}`);
    client.close();
    console.log('Setup complete');
    console.log('='.repeat(60));

    return {
        collection: collectionName,
        recordCount: totalInserted,
    };
}

// ============================================================================
// Main Test
// ============================================================================

export default function(data) {
    const client = milvus.clientWithCollection(CONFIG.host, data.collection, CONFIG.token);

    // Test with different topK values
    const topKValues = [1, 5, 10, 50, 100];

    for (const topK of topKValues) {
        const queryVector = generateVector(CONFIG.vectorDim);
        const result = client.search(
            [queryVector],
            topK,
            {
                vectorField: 'embedding',
                metricType: CONFIG.index.metric,
                outputFields: ['id', 'category', 'price'],
                params: {
                    nprobe: CONFIG.search.nprobe,
                    ef: CONFIG.search.ef,
                },
            }
        );

        searchLatency.add(result.response_time_ms);
        searchOps.add(1);
        errorRate.add(!result.success);

        if (result.success && result.recall !== undefined) {
            const recallPercent = result.recall * 100;

            // Record recall by topK
            switch (topK) {
                case 1:
                    recallTop1.add(recallPercent);
                    break;
                case 5:
                    recallTop5.add(recallPercent);
                    break;
                case 10:
                    recallTop10.add(recallPercent);
                    break;
                case 50:
                    recallTop50.add(recallPercent);
                    break;
                case 100:
                    recallTop100.add(recallPercent);
                    break;
            }

            overallRecall.add(recallPercent);
            recallDistribution.add(recallPercent);

            // Track low recall rate
            const isLowRecall = result.recall < CONFIG.minRecall;
            lowRecallRate.add(isLowRecall);

            check(result, {
                [`recall_topk_${topK}_above_threshold`]: (r) => r.recall >= CONFIG.minRecall,
                [`search_topk_${topK}_successful`]: (r) => r.success === true,
                [`has_${topK}_results`]: (r) => !r.empty && r.result && r.result.length > 0,
            });
        }
    }

    client.close();
    sleep(0.1);
}

// ============================================================================
// Teardown
// ============================================================================

export function teardown(data) {
    console.log('='.repeat(60));
    console.log('Recall Verification Test Summary');
    console.log('='.repeat(60));
    console.log(`Collection: ${data.collection}`);
    console.log(`Records: ${data.recordCount}`);
    console.log(`Index: ${CONFIG.index.type}`);
    console.log(`Min Required Recall: ${CONFIG.minRecall * 100}%`);

    console.log('Cleaning up...');
    const client = milvus.client(CONFIG.host, CONFIG.token);
    const result = client.dropCollection(data.collection);

    if (result.success) {
        console.log(`Collection ${data.collection} dropped`);
    } else {
        console.error(`Failed to drop collection: ${result.error}`);
    }

    client.close();
    console.log('Teardown complete');
}
