// ============================================================================
// Default Setup (can be overridden)
// ============================================================================

export function setup() {
    console.log(`Setting up test: ${CONFIG.scenario.name}`);
    console.log(`Target: ${CONFIG.host}`);
    console.log(`Vector dimension: ${CONFIG.collection.vectorDim}`);

    const client = milvus.client(CONFIG.host, CONFIG.token);
    const collectionName = generateCollectionName();

    // Create collection
    if (!createTestCollection(client, collectionName)) {
        throw new Error('Failed to create test collection');
    }

    // Insert test data
    console.log(`Inserting ${CONFIG.scenario.dataSize} records...`);
    const insertedCount = insertTestData(
        client,
        collectionName,
        CONFIG.scenario.dataSize,
        CONFIG.scenario.batchSize
    );
    console.log(`Inserted ${insertedCount} records`);

    client.close();

    return {
        collection: collectionName,
        insertedCount: insertedCount,
    };
}

// ============================================================================
// Default Test (should be overridden by specific scenarios)
// ============================================================================

export default function(data) {
    const client = milvus.clientWithCollection(CONFIG.host, data.collection, CONFIG.token);

    // Basic search test
    const queryVector = generateVector(CONFIG.collection.vectorDim);
    const result = client.search(
        [queryVector],
        CONFIG.scenario.search.topK,
        {
            vectorField: 'embedding',
            metricType: CONFIG.collection.index.metric,
            outputFields: CONFIG.scenario.search.outputFields,
        }
    );

    searchLatency.add(result.response_time_ms);
    searchOps.add(1);
    errorRate.add(!result.success);
    emptyRate.add(result.empty);

    if (result.recall !== undefined) {
        recallMetric.add(result.recall * 100);
    }

    check(result, {
        'search successful': (r) => r.success === true,
        'has results': (r) => !r.empty,
    });

    client.close();
    sleep(0.1);
}

