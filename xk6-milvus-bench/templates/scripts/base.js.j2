/**
 * Generate a random vector of the specified dimension
 */
function generateVector(dim) {
    const vector = new Array(dim);
    for (let i = 0; i < dim; i++) {
        vector[i] = Math.random();
    }
    return vector;
}

/**
 * Generate multiple random vectors
 */
function generateVectors(count, dim) {
    const vectors = new Array(count);
    for (let i = 0; i < count; i++) {
        vectors[i] = generateVector(dim);
    }
    return vectors;
}

/**
 * Generate a batch of test data
 */
function generateBatchData(count, dim) {
    const categories = ['electronics', 'clothing', 'books', 'food', 'toys'];

    return {
        category: Array.from({ length: count }, () => categories[Math.floor(Math.random() * categories.length)]),
        price: Array.from({ length: count }, () => Math.random() * 100),
        embedding: generateVectors(count, dim),
    };
}

/**
 * Generate a unique collection name
 */
function generateCollectionName() {
    const timestamp = Date.now();
    const random = Math.random().toString(36).substring(2, 8);
    return `${CONFIG.collection.namePrefix}${timestamp}_${random}`;
}

/**
 * Create the test collection with schema
 */
function createTestCollection(client, collectionName) {
    const schema = {
        name: collectionName,
        fields: [
            { name: 'id', dataType: 'Int64', isPrimaryKey: true, isAutoID: true },
            { name: 'category', dataType: 'VarChar', maxLength: 50 },
            { name: 'price', dataType: 'Float' },
            { name: 'embedding', dataType: 'FloatVector', dimension: CONFIG.collection.vectorDim },
        ],
    };

    const result = client.createCollection(schema);
    if (!result.success) {
        console.error(`Failed to create collection: ${result.error}`);
        return false;
    }

    // Create index
    const indexResult = client.createIndex('embedding', {
        indexType: CONFIG.collection.index.type,
        metricType: CONFIG.collection.index.metric,
        params: CONFIG.collection.index.params,
    }, collectionName);

    if (!indexResult.success) {
        console.error(`Failed to create index: ${indexResult.error}`);
        return false;
    }

    // Load collection
    const loadResult = client.loadCollection(collectionName);
    if (!loadResult.success) {
        console.error(`Failed to load collection: ${loadResult.error}`);
        return false;
    }

    return true;
}

/**
 * Insert test data in batches
 */
function insertTestData(client, collectionName, totalSize, batchSize) {
    const batches = Math.ceil(totalSize / batchSize);
    let insertedCount = 0;

    for (let i = 0; i < batches; i++) {
        const count = Math.min(batchSize, totalSize - i * batchSize);
        const data = generateBatchData(count, CONFIG.collection.vectorDim);

        const result = client.insert(data, collectionName);
        if (result.success) {
            insertedCount += result.result.insert_count || count;
        } else {
            console.error(`Batch ${i + 1} insert failed: ${result.error}`);
        }
    }

    return insertedCount;
}

/**
 * Cleanup: drop collection
 */
function cleanupCollection(client, collectionName) {
    const result = client.dropCollection(collectionName);
    if (!result.success) {
        console.error(`Failed to drop collection: ${result.error}`);
    }
}

