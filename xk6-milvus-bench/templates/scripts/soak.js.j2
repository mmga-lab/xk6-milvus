// Generated by xk6-milvus-bench - DO NOT EDIT
// Scenario: {{ scenario.name }}
// Type: soak (stability/endurance test)
// Generated at: {{ generated_at }}

import milvus from 'k6/x/milvus';
import { check, sleep } from 'k6';
import { Trend, Counter, Rate, Gauge } from 'k6/metrics';

// ============================================================================
// Configuration
// ============================================================================

const CONFIG = {
    host: __ENV.MILVUS_HOST || '{{ milvus.host }}',
    token: __ENV.MILVUS_TOKEN || '{{ milvus.token }}',
    vectorDim: {{ collection.vector_dim }},
    topK: {{ scenario.search.topk }},
    outputFields: {{ scenario.search.output_fields | tojson }},
    dataSize: {{ scenario.setup.data_size }},
    batchSize: {{ scenario.setup.batch_size }},
    index: {
        type: '{{ collection.index.type }}',
        metric: '{{ collection.index.metric }}',
        params: {{ collection.index.params | tojson }},
    },
    // Soak test: moderate load, long duration
    checkpointInterval: 60000,  // 1 minute
};

// ============================================================================
// Custom Metrics
// ============================================================================

// Latency metrics
const searchLatency = new Trend('milvus_search_latency', true);
const insertLatency = new Trend('milvus_insert_latency', true);
const queryLatency = new Trend('milvus_query_latency', true);

// Stability metrics
const latencyVariance = new Trend('milvus_latency_variance', true);
const p99Trend = new Trend('milvus_p99_trend', true);

// Operation counters
const searchOps = new Counter('milvus_search_ops');
const insertOps = new Counter('milvus_insert_ops');
const queryOps = new Counter('milvus_query_ops');
const totalOps = new Counter('milvus_total_ops');

// Quality metrics
const recallMetric = new Trend('milvus_recall');
const errorRate = new Rate('milvus_errors');

// Resource tracking
const collectionSize = new Gauge('milvus_collection_size');

// Checkpoint metrics (for long-running analysis)
let checkpointData = {
    searches: [],
    inserts: [],
    lastCheckpoint: Date.now(),
};

// ============================================================================
// k6 Options - Soak Test
// ============================================================================

export const options = {
{% if execution.stages %}
    stages: [
{% for stage in execution.stages %}
        { duration: '{{ stage.duration }}', target: {{ stage.target }} },
{% endfor %}
    ],
{% else %}
    // Soak scenario: constant moderate load for extended duration
    scenarios: {
        soak_test: {
            executor: 'constant-vus',
            vus: {{ execution.vus }},
            duration: '{{ execution.duration }}',
        },
    },
{% endif %}
    thresholds: {
        // Soak tests have slightly relaxed thresholds but focus on stability
        'milvus_search_latency': ['p(95)<{{ thresholds.search_p95_ms }}', 'p(99)<{{ thresholds.search_p99_ms }}'],
        'milvus_insert_latency': ['p(95)<{{ thresholds.insert_p95_ms }}'],
        'milvus_errors': ['rate<{{ thresholds.max_error_rate }}'],
        'milvus_recall': ['avg>={{ (thresholds.min_recall * 100) | int }}'],
        // Stability: latency variance should be low
        'milvus_latency_variance': ['avg<50'],  // Variance should stay under 50ms
    },
    tags: {
        scenario: '{{ scenario.name }}',
        type: 'soak',
        testrun: __ENV.TESTRUN_NAME || 'local',
    },
};

// ============================================================================
// Helper Functions
// ============================================================================

function generateVector(dim) {
    const vector = new Array(dim);
    for (let i = 0; i < dim; i++) {
        vector[i] = Math.random();
    }
    return vector;
}

function generateVectors(count, dim) {
    const vectors = new Array(count);
    for (let i = 0; i < count; i++) {
        vectors[i] = generateVector(dim);
    }
    return vectors;
}

function generateBatchData(count, dim) {
    const categories = ['electronics', 'clothing', 'books', 'food', 'toys'];
    return {
        category: Array.from({ length: count }, () => categories[Math.floor(Math.random() * categories.length)]),
        price: Array.from({ length: count }, () => Math.random() * 100),
        embedding: generateVectors(count, dim),
    };
}

function recordCheckpoint(latency, operationType) {
    const now = Date.now();

    if (operationType === 'search') {
        checkpointData.searches.push(latency);
    } else if (operationType === 'insert') {
        checkpointData.inserts.push(latency);
    }

    // Log checkpoint every minute
    if (now - checkpointData.lastCheckpoint > CONFIG.checkpointInterval) {
        if (checkpointData.searches.length > 0) {
            const avgSearch = checkpointData.searches.reduce((a, b) => a + b, 0) / checkpointData.searches.length;
            console.log(`[Checkpoint] Search avg: ${avgSearch.toFixed(2)}ms, samples: ${checkpointData.searches.length}`);
        }
        if (checkpointData.inserts.length > 0) {
            const avgInsert = checkpointData.inserts.reduce((a, b) => a + b, 0) / checkpointData.inserts.length;
            console.log(`[Checkpoint] Insert avg: ${avgInsert.toFixed(2)}ms, samples: ${checkpointData.inserts.length}`);
        }

        // Reset checkpoint data
        checkpointData.searches = [];
        checkpointData.inserts = [];
        checkpointData.lastCheckpoint = now;
    }
}

// ============================================================================
// Setup
// ============================================================================

export function setup() {
    console.log('='.repeat(60));
    console.log('Soak/Stability Test Setup');
    console.log('='.repeat(60));
    console.log(`Target: ${CONFIG.host}`);
    console.log(`Vector Dim: ${CONFIG.vectorDim}`);
    console.log(`Initial Data Size: ${CONFIG.dataSize}`);
    console.log('This test will run for an extended period to detect memory leaks,');
    console.log('performance degradation, and stability issues.');

    const client = milvus.client(CONFIG.host, CONFIG.token);
    const collectionName = `perf_soak_${Date.now()}`;

    // Create collection
    const schema = {
        name: collectionName,
        fields: [
            { name: 'id', dataType: 'Int64', isPrimaryKey: true, isAutoID: true },
            { name: 'category', dataType: 'VarChar', maxLength: 50 },
            { name: 'price', dataType: 'Float' },
            { name: 'embedding', dataType: 'FloatVector', dimension: CONFIG.vectorDim },
        ],
    };

    const createResult = client.createCollection(schema);
    if (!createResult.success) {
        throw new Error(`Failed to create collection: ${createResult.error}`);
    }
    console.log(`Collection created: ${collectionName}`);

    // Create index
    const indexResult = client.createIndex('embedding', {
        indexType: CONFIG.index.type,
        metricType: CONFIG.index.metric,
        params: CONFIG.index.params,
    }, collectionName);

    if (!indexResult.success) {
        throw new Error(`Failed to create index: ${indexResult.error}`);
    }

    // Load collection
    client.loadCollection(collectionName);

    // Insert initial data
    console.log(`Inserting ${CONFIG.dataSize} initial records...`);
    const batches = Math.ceil(CONFIG.dataSize / CONFIG.batchSize);
    let totalInserted = 0;

    for (let i = 0; i < batches; i++) {
        const count = Math.min(CONFIG.batchSize, CONFIG.dataSize - i * CONFIG.batchSize);
        const data = generateBatchData(count, CONFIG.vectorDim);
        const result = client.insert(data, collectionName);

        if (result.success) {
            totalInserted += result.result.insert_count || count;
        }
    }

    console.log(`Initial data inserted: ${totalInserted}`);
    client.close();
    console.log('Setup complete - starting soak test');
    console.log('='.repeat(60));

    return {
        collection: collectionName,
        initialCount: totalInserted,
        startTime: Date.now(),
    };
}

// ============================================================================
// Main Test
// ============================================================================

export default function(data) {
    const client = milvus.clientWithCollection(CONFIG.host, data.collection, CONFIG.token);

    // Track previous latencies for variance calculation
    let prevSearchLatency = null;

    // 80% search, 15% insert, 5% query
    const rand = Math.random();

    if (rand < 0.80) {
        // Search operation
        const queryVector = generateVector(CONFIG.vectorDim);
        const result = client.search(
            [queryVector],
            CONFIG.topK,
            {
                vectorField: 'embedding',
                metricType: CONFIG.index.metric,
                outputFields: CONFIG.outputFields,
            }
        );

        searchLatency.add(result.response_time_ms);
        searchOps.add(1);
        totalOps.add(1);
        errorRate.add(!result.success);

        // Calculate variance from previous latency
        if (prevSearchLatency !== null) {
            const variance = Math.abs(result.response_time_ms - prevSearchLatency);
            latencyVariance.add(variance);
        }
        prevSearchLatency = result.response_time_ms;

        // Record p99 trend
        p99Trend.add(result.response_time_ms);

        if (result.recall !== undefined) {
            recallMetric.add(result.recall * 100);
        }

        recordCheckpoint(result.response_time_ms, 'search');

        check(result, {
            'search_successful': (r) => r.success === true,
            'latency_under_threshold': (r) => r.response_time_ms < {{ thresholds.search_p99_ms * 2 }},
        });

    } else if (rand < 0.95) {
        // Insert operation (to simulate data growth)
        const batchSize = 50;  // Small batches to simulate continuous ingestion
        const batchData = generateBatchData(batchSize, CONFIG.vectorDim);

        const result = client.insert(batchData);

        insertLatency.add(result.response_time_ms);
        insertOps.add(1);
        totalOps.add(1);
        errorRate.add(!result.success);

        recordCheckpoint(result.response_time_ms, 'insert');

        // Track collection growth
        if (result.success) {
            collectionSize.add(batchSize);
        }

        check(result, {
            'insert_successful': (r) => r.success === true,
        });

    } else {
        // Query operation
        const filters = [
            'price > 50',
            'price < 30',
            "category == 'electronics'",
        ];
        const filter = filters[Math.floor(Math.random() * filters.length)];

        const result = client.query(filter, ['id', 'category', 'price']);

        queryLatency.add(result.response_time_ms);
        queryOps.add(1);
        totalOps.add(1);
        errorRate.add(!result.success);

        check(result, {
            'query_successful': (r) => r.success === true,
        });
    }

    client.close();

    // Moderate sleep to avoid overwhelming during soak
    sleep(0.2);
}

// ============================================================================
// Teardown
// ============================================================================

export function teardown(data) {
    const duration = (Date.now() - data.startTime) / 1000 / 60;  // minutes

    console.log('='.repeat(60));
    console.log('Soak Test Summary');
    console.log('='.repeat(60));
    console.log(`Collection: ${data.collection}`);
    console.log(`Initial Records: ${data.initialCount}`);
    console.log(`Test Duration: ${duration.toFixed(2)} minutes`);

    console.log('Cleaning up...');
    const client = milvus.client(CONFIG.host, CONFIG.token);
    const result = client.dropCollection(data.collection);

    if (result.success) {
        console.log(`Collection ${data.collection} dropped`);
    } else {
        console.error(`Failed to drop collection: ${result.error}`);
    }

    client.close();
    console.log('Teardown complete');
}
