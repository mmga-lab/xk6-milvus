# Generated by xk6-milvus-bench - DO NOT EDIT
# Scenario: {{ scenario.name }}
# Generated at: {{ generated_at }}

apiVersion: k6.io/v1alpha1
kind: TestRun
metadata:
  name: {{ testrun_name }}
  namespace: {{ kubernetes.namespace }}
  labels:
    app: xk6-milvus-bench
    scenario: {{ scenario.name }}
    type: {{ scenario.type }}
spec:
  parallelism: {{ kubernetes.parallelism }}

  script:
    configMap:
      name: {{ configmap_name }}
      file: {{ script_filename }}

  runner:
    image: {{ kubernetes.image }}
    imagePullPolicy: Always

    env:
      - name: MILVUS_HOST
        value: "{{ milvus.host }}"
{% if milvus.token %}
      - name: MILVUS_TOKEN
        valueFrom:
          secretKeyRef:
            name: milvus-credentials
            key: token
            optional: true
{% endif %}
      - name: TESTRUN_NAME
        value: "{{ testrun_name }}"
      - name: K6_SCENARIO
        value: "{{ scenario.name }}"
{% if prometheus.enabled %}
      - name: K6_PROMETHEUS_RW_SERVER_URL
        value: "{{ prometheus.remote_write_url }}"
      - name: K6_PROMETHEUS_RW_TREND_AS_NATIVE_HISTOGRAM
        value: "true"
{% endif %}

    resources:
      requests:
        cpu: "{{ kubernetes.resources.requests.cpu }}"
        memory: "{{ kubernetes.resources.requests.memory }}"
      limits:
        cpu: "{{ kubernetes.resources.limits.cpu }}"
        memory: "{{ kubernetes.resources.limits.memory }}"

    # Optional: Node selector
    # nodeSelector:
    #   kubernetes.io/arch: amd64

    # Optional: Tolerations
    # tolerations:
    #   - key: "dedicated"
    #     operator: "Equal"
    #     value: "performance-testing"
    #     effect: "NoSchedule"

{% if prometheus.enabled %}
  arguments: --out experimental-prometheus-rw
{% endif %}

  # Cleanup policy: delete pods after completion
  cleanup: post
